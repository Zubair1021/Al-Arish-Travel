# Copy this file to .env and fill in real values
PORT=5000

# Local: mongodb://127.0.0.1:27017/alarish
# Atlas: mongodb+srv://USER:PASS@cluster.mongodb.net/alarish?appName=Alarish-T
MONGODB_URI=mongodb://127.0.0.1:27017/alarish

# Database name. Overrides whatever is (or isn't) in MONGODB_URI.
# Prevents Mongoose from defaulting to "test" when the URI omits a DB.
MONGODB_DB=alarish

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173

# Seed admin (only used when no admin exists in DB)
ADMIN_EMAIL=uzmanadmin@gmail.com
ADMIN_PASSWORD=admin@12345
